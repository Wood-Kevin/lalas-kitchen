{
  "expo": {
    "name": "Lala's Kitchen",
    "slug": "lalas-kitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "RCTAsyncStorageExcludeFromBackup": false
      }
    },
    "android": {
      "package": "com.kevinw2284.lalaskitchen",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F6D9A8"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1884558565604210~2303142978",
          "iosAppId": "ca-app-pub-1884558565604210~6252784828"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5d411090-9f71-422f-8bb1-8a23219449ea"
      }
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-1884558565604210~2303142978"
  }
}
